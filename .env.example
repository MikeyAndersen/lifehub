# ── Telegram ────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456:ABC...            # from @BotFather
TELEGRAM_WEBHOOK_SECRET=change-me-long-random
TELEGRAM_ALLOWED_CHAT_IDS=11111111,22222222 # family chat ids
TELEGRAM_ADMIN_CHAT_ID=11111111             # Mikey — only id allowed finance intents

# ── LLM / transcription ─────────────────────────────────────
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:7b-instruct
WHISPER_MODEL=medium                        # small = faster on CPU

# ── Google Calendar ──────────────────────────────────────────
GOOGLE_TOKEN_PATH=/secrets/token.json
DEFAULT_CALENDAR_ID=primary                 # or the shared "Familien" calendar id
BIRTHDAYS_CALENDAR_ID=addressbook#contacts@group.v.calendar.google.com

# ── Vikunja ──────────────────────────────────────────────────
VIKUNJA_URL=http://vikunja:3456
VIKUNJA_TOKEN=tk_...                        # Settings → API tokens
VIKUNJA_DEFAULT_PROJECT_ID=1
VIKUNJA_SHOPPING_PROJECT_ID=2

# ── Gmail / Aula-indlæsning (Del 3) ──────────────────────────
GMAIL_ENABLED=true
GMAIL_LABEL=Aula                    # Gmail-labelnavn; opløses til labelId ved opstart
GMAIL_POLL_MINUTES=10
GMAIL_MAX_PER_POLL=10               # rate-limit; resten tages næste poll
GMAIL_LOOKBACK_DAYS=7               # ved fuld resync (historyId udløbet)

AULA_MAX_BODY_CHARS=4000            # trunkering efter sanering
AULA_SENDER_ALLOWLIST=aula.dk       # kommasepareret; suffix-match på From-domæne
AULA_MAX_ITEMS_PER_MAIL=5

# Hybrid auto-mode. Start med false, kør 1-2 uger i forslag-only og
# kalibrér AULA_AUTO_MIN_CONFIDENCE ud fra gate-loggen — slå så til.
AULA_AUTO_ENABLED=false
AULA_AUTO_INTENTS=event             # v1 = kun event; handling er bevidst udeladt
AULA_AUTO_MIN_CONFIDENCE=0.85
AULA_AUTO_MAX_DAYS_AHEAD=90         # auto kun for datoer inden for horisont

AULA_PROPOSAL_TTL_HOURS=72          # herefter markeres forslag expired
AULA_URGENT_HOURS=24                # deadline/dato < dette → straks-besked

# ── Generel post-triage (Del 4) ──────────────────────────────
# Hele INBOX minus støj (Promotions/Social/List-Unsubscribe filtreres før
# LLM). Admin-only overalt; ingen auto-handlinger — kun highlights og
# forslag med knapper. Deler poll-interval og TTL med Aula-streamen.
TRIAGE_ENABLED=false
TRIAGE_LOOKBACK_DAYS=3              # ved fuld resync (historyId udløbet)

# ── Dashboard / privacy ──────────────────────────────────────
ADMIN_EMAILS=mikey@example.dk               # Cf-Access emails that may see finance
TZ=Europe/Copenhagen
LATITUDE=56.15
LONGITUDE=10.21
ELPRIS_AREA=DK1

# ── Madplan-integration (Fase 2) ─────────────────────────────
# Ugeplan-feed fra nova-madplan. Tom MADPLAN_URL slår feed'et fra.
# Kræver at brain og madplan-api deler det eksterne net lifehub_net
# (docker network create lifehub_net).
MADPLAN_URL=http://madplan-api:8000
LIFEHUB_API_TOKEN=                  # SAMME værdi som i nova-madplan/.env (openssl rand -hex 32)
MADPLAN_POLL_MINUTES=10
MADPLAN_STALE_MINUTES=10            # cache ældre end dette markeres stale på dashboardet

# Intern lager-proxy (Fase 3): madplan → brain GET /api/internal/inventory.
# Tomt token = endpointet lukket. SAMME værdi som INTERNAL_API_TOKEN i nova-madplan/.env.
INTERNAL_API_TOKEN=                 # openssl rand -hex 32
INVENTORY_DONE_DAYS=7              # afsluttede indkøb inden for X dage = "på lager"

# ── Storage ──────────────────────────────────────────────────
DB_PATH=/data/lifehub.db
