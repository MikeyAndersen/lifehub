# Copy to agent/.env and fill in. Real environment variables take precedence.

# LifeHub server — use the LAN address, NOT the public Cloudflare URL
# (Cloudflare Access would answer the drain endpoint with a login redirect).
LIFEHUB_SERVER_URL=http://192.168.0.145:8080

# Must match REVIEW_DRAIN_TOKEN in the server's .env.
REVIEW_DRAIN_TOKEN=

# The strong model to unload when done (same as the server's STRONG_OLLAMA_MODEL).
OLLAMA_MODEL=qwen2.5:32b-instruct

# Optional overrides:
#GPU_START_THRESHOLD=30
#TIMEBOX_MINUTES=10
#OLLAMA_URL=http://localhost:11434
